rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Access
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Security Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn(); // Relaxed to allow sandbox auth testing without strict email verification
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.:]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Validation Blueprints (Anti-Update-Gap & Strong Types)
    function isValidOpCoConfig(data) {
      return data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() <= 256 &&
             data.updatedAt is timestamp &&
             data.assumptions is map;
    }

    function isValidPropCoConfig(data) {
      return data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() <= 256 &&
             data.updatedAt is timestamp &&
             data.assumptions is map;
    }

    function isValidProject(data) {
      return data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() <= 256 &&
             data.updatedAt is timestamp &&
             data.projectInfo is map &&
             data.opCoAssumptions is map &&
             data.propCoAssumptions is map &&
             (!data.keys().hasAll(['collaborators']) || data.collaborators is list);
    }

    // 4. OpCo Configurations Document Rules
    match /opcoConfigs/{userId} {
      allow get: if isEmailVerified() && userId == request.auth.uid;
      
      allow create: if isEmailVerified() &&
                       userId == request.auth.uid &&
                       isValidId(userId) &&
                       isValidOpCoConfig(incoming()) &&
                       incoming().userId == request.auth.uid &&
                       incoming().userEmail == request.auth.token.email &&
                       incoming().updatedAt == request.time &&
                       incoming().keys().hasAll(['userId', 'userEmail', 'updatedAt', 'assumptions']) &&
                       incoming().keys().size() == 4;

      allow update: if isEmailVerified() &&
                       userId == request.auth.uid &&
                       isValidId(userId) &&
                       isValidOpCoConfig(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().userEmail == existing().userEmail &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'assumptions']);

      allow delete: if isEmailVerified() && userId == request.auth.uid && isValidId(userId);
    }

    // 5. PropCo Configurations Document Rules
    match /propcoConfigs/{userId} {
      allow get: if isEmailVerified() && userId == request.auth.uid;

      allow create: if isEmailVerified() &&
                       userId == request.auth.uid &&
                       isValidId(userId) &&
                       isValidPropCoConfig(incoming()) &&
                       incoming().userId == request.auth.uid &&
                       incoming().userEmail == request.auth.token.email &&
                       incoming().updatedAt == request.time &&
                       incoming().keys().hasAll(['userId', 'userEmail', 'updatedAt', 'assumptions']) &&
                       incoming().keys().size() == 4;

      allow update: if isEmailVerified() &&
                       userId == request.auth.uid &&
                       isValidId(userId) &&
                       isValidPropCoConfig(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().userEmail == existing().userEmail &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'assumptions']);

      allow delete: if isEmailVerified() && userId == request.auth.uid && isValidId(userId);
    }

    // 6. User Projects Rules with Multi-User Collaboration Gates
    match /users/{userId}/projects/{projectId} {
      allow get: if isSignedIn() && (
        userId == request.auth.uid || 
        (resource != null && resource.data.collaborators != null && request.auth.token.email in resource.data.collaborators)
      );

      allow list: if isSignedIn() && (
        userId == request.auth.uid || 
        (resource != null && resource.data.collaborators != null && request.auth.token.email in resource.data.collaborators)
      );

      allow create: if isSignedIn() &&
                       userId == request.auth.uid &&
                       isValidId(projectId) &&
                       isValidProject(incoming()) &&
                       incoming().userId == request.auth.uid &&
                       incoming().userEmail == request.auth.token.email &&
                       incoming().updatedAt == request.time;

      allow update: if isSignedIn() &&
                       isValidId(projectId) &&
                       isValidProject(incoming()) && (
                         // Owner update
                         (userId == request.auth.uid && incoming().userId == existing().userId) ||
                         // Collaborator update (can't change owner or modify existing collaborator array unless they are owner)
                         (resource != null && resource.data.collaborators != null && request.auth.token.email in resource.data.collaborators &&
                          incoming().userId == existing().userId &&
                          incoming().userEmail == existing().userEmail &&
                          (!existing().keys().hasAll(['collaborators']) || incoming().collaborators == existing().collaborators))
                       ) &&
                       incoming().updatedAt == request.time;

      allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(projectId);
    }
  }
}
